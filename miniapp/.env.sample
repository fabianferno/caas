AUTH_SECRET="" # Added by `pnpm exec auth secret`. Read more: https://cli.authjs.dev
# Set to true when using ngrok, preview URLs, or if you still see UntrustedHost in dev
# AUTH_TRUST_HOST=true
HMAC_SECRET_KEY='some-secret' # create this by running `openssl rand -base64 32`
AUTH_URL='' # For testing this should be your NGROK URL and for production this should be your production URL
NEXT_PUBLIC_APP_ID='app_1234567890' # APP ID from the developer portal
# World ID Verify (IDKit v4 RP flow) — from Developer Portal for this app
RP_SIGNING_KEY=''
# Optional; defaults to rp_e87d44dbb7b76d91 in src/app/api/rp-signature/route.ts if unset
# RP_ID=''